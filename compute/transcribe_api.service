[Unit]
Description=Harmony Transcription API (faster-whisper)
After=network-online.target tailscaled.service
Wants=network-online.target

[Service]
Type=simple
# Edit User= and the home path below to match the target machine before installing.
User=aaron
WorkingDirectory=%h/Documents/harmony
# %h does not expand in EnvironmentFile — set absolute path matching User= above.
EnvironmentFile=/home/aaron/Documents/harmony/.env
ExecStart=%h/Documents/harmony/.venv/bin/uvicorn compute.transcribe_api:app \
    --host ${FORGE_TAILSCALE_IP} \
    --port 8765
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target
